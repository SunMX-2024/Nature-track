button {
  margin: 0;
  padding: 0;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 20rpx;
  padding-top: 96rpx;
  box-sizing: border-box;
}

.topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  gap: 10rpx;
  height: 78rpx;
  padding: 10rpx 18rpx;
  box-sizing: border-box;
  background: rgba(235, 233, 225, 0.96);
  border-bottom: 1rpx solid rgba(79, 88, 81, 0.12);
  backdrop-filter: blur(14rpx);
}

.menu-button {
  width: 46rpx;
  height: 46rpx;
  flex: 0 0 46rpx;
  border: 1rpx solid rgba(79, 88, 81, 0.2);
  border-radius: 10rpx;
  background: #f5f4ef;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5rpx;
}

.menu-button text {
  display: block;
  width: 22rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #4e5b51;
}

.topbar-copy {
  flex: 1;
  min-width: 0;
}

.result-count {
  flex: 0 0 auto;
  max-width: 118rpx;
  color: #6f7c70;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.15;
  text-align: right;
}

.header {
  padding: 0 0 14rpx;
}

.kicker {
  display: block;
  color: #6f7c70;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 1rpx;
  text-transform: uppercase;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.title {
  display: block;
  margin-top: 3rpx;
  color: #252a27;
  font-size: 34rpx;
  font-weight: 780;
  line-height: 1.05;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  color: #59615b;
  font-size: 25rpx;
  line-height: 1.4;
}

.filter-summary {
  display: block;
  width: 100%;
  margin-top: 12rpx;
  min-height: 54rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(79, 88, 81, 0.18);
  border-radius: 10rpx;
  background: #f5f4ef;
  color: #4e5b51;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 54rpx;
  text-align: left;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.drawer-mask {
  position: fixed;
  z-index: 40;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(37, 42, 39, 0.24);
}

.filter-drawer {
  position: fixed;
  z-index: 50;
  top: 0;
  left: 0;
  bottom: 0;
  width: 84vw;
  max-width: 650rpx;
  padding: 18rpx;
  padding-top: 22rpx;
  box-sizing: border-box;
  background: #ebe9e1;
  border-right: 1rpx solid rgba(79, 88, 81, 0.18);
  box-shadow: 18rpx 0 60rpx rgba(62, 68, 61, 0.22);
  transform: translateX(-104%);
  transition: transform 180ms ease;
  overflow-y: auto;
}

.filter-drawer.open {
  transform: translateX(0);
}

.drawer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.drawer-head text {
  color: #252a27;
  font-size: 30rpx;
  font-weight: 760;
}

.drawer-head button {
  width: auto;
  min-width: 96rpx;
  height: 48rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(79, 88, 81, 0.2);
  border-radius: 10rpx;
  background: #f5f4ef;
  color: #4e5b51;
  font-size: 22rpx;
  line-height: 48rpx;
}

.panel,
.article-card {
  border: 1rpx solid rgba(79, 88, 81, 0.18);
  border-radius: 14rpx;
  background: rgba(250, 249, 244, 0.9);
  box-shadow: 0 12rpx 34rpx rgba(62, 68, 61, 0.08);
}

.panel {
  padding: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  margin: 2rpx 0 8rpx;
  color: #59615b;
  font-size: 20rpx;
  font-weight: 760;
  line-height: 1.2;
  text-transform: uppercase;
}

.journal-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.journal-chip,
.segmented button,
.actions button,
.day-option {
  min-height: 48rpx;
  height: auto;
  padding: 7rpx 12rpx;
  border: 1rpx solid rgba(79, 88, 81, 0.22);
  border-radius: 9rpx;
  background: #f5f4ef;
  color: #3c443f;
  font-size: 21rpx;
  line-height: 1.2;
  white-space: normal;
  word-break: normal;
  overflow-wrap: break-word;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.journal-chip {
  width: auto;
  min-width: 124rpx;
  max-width: 100%;
  flex: 0 1 auto;
}

.journal-chip.active,
.segmented button.active,
.day-option.active {
  background: #4e5b51;
  border-color: #4e5b51;
  color: #fffdf8;
}

.custom-journal-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin: 8rpx 0 16rpx;
}

.custom-journal-input {
  flex: 1;
  min-width: 0;
  height: 52rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(79, 88, 81, 0.18);
  border-radius: 10rpx;
  background: #f5f4ef;
  color: #252a27;
  font-size: 23rpx;
}

.custom-journal-button {
  width: 96rpx;
  height: 52rpx;
  border-radius: 10rpx;
  background: #d7ded1;
  color: #3c443f;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 52rpx;
}

.keyword-box {
  width: 100%;
  min-height: 132rpx;
  padding: 14rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(79, 88, 81, 0.18);
  border-radius: 10rpx;
  background: #f5f4ef;
  color: #252a27;
  font-size: 25rpx;
  line-height: 1.42;
}

.segmented {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.segmented button {
  flex: 1 1 190rpx;
  min-width: 0;
}

.segmented.scope button {
  flex-basis: 148rpx;
}

.days-selector {
  position: relative;
  margin-top: 14rpx;
}

.days-button {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 62rpx;
  padding: 8rpx 14rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(79, 88, 81, 0.18);
  border-radius: 10rpx;
  background: #f5f4ef;
}

.days-label {
  display: block;
  color: #6f7c70;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.1;
}

.days-value {
  display: block;
  margin-top: 3rpx;
  color: #252a27;
  font-size: 26rpx;
  font-weight: 780;
  line-height: 1.15;
}

.chevron {
  display: block;
  width: 34rpx;
  height: 34rpx;
  color: #4e5b51;
  font-size: 26rpx;
  line-height: 34rpx;
  text-align: center;
  transform: rotate(0deg);
  transition: transform 160ms ease;
}

.chevron.open {
  transform: rotate(180deg);
}

.days-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.day-option {
  flex: 1 1 118rpx;
  min-width: 0;
  font-weight: 700;
}

.search-button {
  margin-top: 16rpx;
  height: 66rpx;
  border-radius: 11rpx;
  background: #4e5b51;
  color: #fffdf8;
  font-size: 27rpx;
  font-weight: 760;
  line-height: 66rpx;
}

.error,
.empty {
  margin: 16rpx 0;
  padding: 18rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.error {
  background: #f3dedb;
  color: #8d625d;
}

.empty {
  background: rgba(255, 255, 250, 0.56);
  color: #7b827a;
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.article-card {
  padding: 20rpx;
}

.article-title {
  display: block;
  color: #252a27;
  font-size: 30rpx;
  font-weight: 760;
  line-height: 1.34;
}

.journal {
  display: block;
  margin-top: 8rpx;
  color: #6f7c70;
  font-size: 24rpx;
  font-weight: 700;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.meta text {
  padding: 4rpx 12rpx;
  border: 1rpx solid rgba(79, 88, 81, 0.14);
  border-radius: 999rpx;
  color: #7b827a;
  font-size: 21rpx;
}

.abstract {
  margin-top: 16rpx;
  color: #3c443f;
  font-size: 26rpx;
  line-height: 1.62;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.actions button {
  flex: 1 1 168rpx;
  min-width: 0;
}
